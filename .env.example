# === Required ===
POSTGRES_PASSWORD=changeme
JWT_SECRET=changeme

# === LLM / Embedding server URLs ===
LLM_URL=http://host.docker.internal:8081/v1
EMBED_URL=http://host.docker.internal:8082/v1

# === Optional: OCR server (host GPU) ===
# OCR_SERVER_URL=http://host.docker.internal:8090

# === Optional: Sentry error tracking ===
# SENTRY_DSN=

# === Optional: S3 backup (scripts/backup-s3.sh) ===
# S3_ENDPOINT=https://s3.example.com
# S3_BUCKET=s3://your-bucket-name
# AWS_PROFILE=default
