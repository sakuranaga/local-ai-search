# Local AI Search
LAS_BASE_URL=http://localhost:8000
LAS_API_KEY=your_las_api_key

# Polling interval (seconds, default: 300 = 5 minutes)
POLL_INTERVAL=300

# Hash store path (container 内のパス、volume でマウントして永続化)
HASH_STORE_PATH=/data/hashes.json

# Notion Sync Configs
# Token と Page ID をセットで設定。番号(1,2,3...)で複数ワークスペース対応。
# PAGE_IDS はカンマ区切りで複数ページ指定可。
# FOLDER は LAS 上の保存先フォルダ（省略時: "Notion"）。

NOTION_SYNC_1_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_SYNC_1_PAGE_IDS=page_id_1,page_id_2
NOTION_SYNC_1_FOLDER=Notion/Workspace1

# NOTION_SYNC_2_TOKEN=secret_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
# NOTION_SYNC_2_PAGE_IDS=page_id_3
# NOTION_SYNC_2_FOLDER=Notion/Workspace2
